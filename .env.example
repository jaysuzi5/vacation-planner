# Copy this to .env and fill in real values. Never commit .env.
DEBUG=True
SECRET_KEY=replace-with-a-real-secret-key-at-least-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL — external k8s address for local dev
DATABASE_URL=postgres://jcurtis:PASSWORD@192.168.86.201:30004/vacation_planner

# django-allauth
ACCOUNT_EMAIL_VERIFICATION=optional

# CSRF — add production domain in production .env
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Email (Gmail SMTP) — leave blank for local dev (console backend used when DEBUG=True)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
